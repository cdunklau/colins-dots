# Use a different file for custom bits so we can easily
# get the distribution's latest from /etc/skel/.bashrc.
#
# Source this file in .bashrc proper to enable.

# Prompt hack (see make_prompt.py in the colins-dots repo)
_git_info_line() {
    BRANCH_NAME=$(
        git branch --list 2> /dev/null |
            sed -e '/^[^*]/d' -e 's/* \(.*\)/\1/'
    )
    if [ -n "$BRANCH_NAME" ]; then
        echo -e "\\ngit: branch=\033[01;31m$BRANCH_NAME\033[00m"
    fi
};

export PS1="\[\e]0;\u@\h: \w\a\]\[\033[00m\][\[\033[01;32m\]\u\[\033[00m\]@\[\033[01;32m\]\h\[\033[00m\]] \t \[\033[01;34m\]\w\[\033[00m\]\$(_git_info_line)\n--> \\$ \[\033[00m\]"

# Editor
export EDITOR=vim


# pyenv setup
PYENV_ROOT="$HOME/.pyenv"
if [ -d "$PYENV_ROOT" ]; then
    export PYENV_ROOT
    export PATH="$PYENV_ROOT/bin:$PATH"
    eval "$(pyenv init -)"
fi

# Haskell stuff
HASKELL_INIT="$HOME/.ghcup/env"
if [ -f "$HASKELL_INIT" ]; then
    source ${HASKELL_INIT}
fi

# Rust stuff
RUST_INIT="$HOME/.cargo/env"
if [ -f "$RUST_INIT" ]; then
    source ${RUST_INIT}
fi
